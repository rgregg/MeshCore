{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB v2 datasource for MeshCore telemetry",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "id": null,
  "uid": "meshcore-telemetry",
  "title": "MeshCore Repeater Dashboard",
  "description": "Native MQTT telemetry dashboard for MeshCore ETH-enabled repeaters and room servers",
  "tags": ["meshcore", "lora", "mqtt"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "custom",
        "current": { "text": "MeshCore", "value": "MeshCore" },
        "options": [
          { "text": "MeshCore", "value": "MeshCore", "selected": true }
        ],
        "query": "MeshCore"
      },
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"node_id\", predicate: (r) => r._measurement == \"meshcore_core\")",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "range", "options": { "from": 0, "to": 120, "result": { "text": "ONLINE", "color": "green", "index": 0 } } },
            { "type": "range", "options": { "from": 120, "to": 999999999, "result": { "text": "OFFLINE", "color": "red", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_core\" and r._field == \"uptime_secs\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> map(fn: (r) => ({ r with _value: int(v: now()) / 1000000000 - int(v: r._time) / 1000000000 }))\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_core\" and r._field == \"uptime_secs\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Battery",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "mvolt",
          "min": 3000,
          "max": 4200,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3300 },
              { "color": "yellow", "value": 3500 },
              { "color": "green", "value": 3700 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_core\" and r._field == \"battery_mv\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Queue Length",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_core\" and r._field == \"queue_len\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Noise Floor",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -120 },
              { "color": "green", "value": -110 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_radio\" and r._field == \"noise_floor\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Last RSSI",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -110 },
              { "color": "yellow", "value": -90 },
              { "color": "green", "value": -70 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_radio\" and r._field == \"last_rssi\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Last SNR",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -5 },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_radio\" and r._field == \"last_snr\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_core\" and r._field == \"errors\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> last()\n  |> drop(columns: [\"topic\", \"host\"])"
        }
      ]
    },
    {
      "title": "Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Packets Received / Sent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto",
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_packet_stats\")\n  |> filter(fn: (r) => r._field == \"recv\" or r._field == \"sent\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> difference(nonNegative: true)\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Flood vs Direct Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" },
            "lineWidth": 0
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "flood_rx" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "flood_tx" }, "properties": [{ "id": "color", "value": { "fixedColor": "light-blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "direct_rx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "direct_tx" }, "properties": [{ "id": "color", "value": { "fixedColor": "light-green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_packet_stats\")\n  |> filter(fn: (r) => r._field == \"flood_rx\" or r._field == \"flood_tx\" or r._field == \"direct_rx\" or r._field == \"direct_tx\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> difference(nonNegative: true)\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Packet Type Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_packets\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> group(columns: [\"packet_type\"])\n  |> count()\n  |> group()\n  |> keep(columns: [\"packet_type\", \"_value\"])\n  |> rename(columns: {packet_type: \"_field\"})\n  |> map(fn: (r) => ({\n      r with\n      _field: if r._field == \"0\" then \"REQ\"\n        else if r._field == \"1\" then \"RESP\"\n        else if r._field == \"2\" then \"TXT\"\n        else if r._field == \"3\" then \"ACK\"\n        else if r._field == \"4\" then \"ADVERT\"\n        else if r._field == \"5\" then \"GRP_TXT\"\n        else if r._field == \"6\" then \"GRP_DATA\"\n        else if r._field == \"7\" then \"ANON_REQ\"\n        else if r._field == \"8\" then \"PATH\"\n        else if r._field == \"9\" then \"TRACE\"\n        else if r._field == \"10\" then \"MULTI\"\n        else if r._field == \"11\" then \"CTRL\"\n        else if r._field == \"15\" then \"RAW\"\n        else r._field\n  }))"
        }
      ]
    },
    {
      "title": "RX vs TX Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "rx" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "tx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_packets\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> group(columns: [\"direction\"])\n  |> count()\n  |> group()\n  |> keep(columns: [\"direction\", \"_value\"])\n  |> rename(columns: {direction: \"_field\"})"
        }
      ]
    },
    {
      "title": "Receive Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_packet_stats\" and r._field == \"recv_errors\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> difference(nonNegative: true)\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Radio",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "RSSI Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto"
          },
          "unit": "dBm",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "noise_floor" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 5 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_radio\")\n  |> filter(fn: (r) => r._field == \"last_rssi\" or r._field == \"noise_floor\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "title": "SNR Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto"
          },
          "unit": "dB",
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_radio\" and r._field == \"last_snr\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> drop(columns: [\"topic\", \"host\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Airtime (TX / RX)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
