{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB v2 datasource for MeshCore telemetry",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "geomap", "name": "Geomap", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "uid": "meshcore-neighbors",
  "title": "MeshCore Neighbors",
  "description": "Map and table of nodes discovered via MeshCore advertisements",
  "tags": ["meshcore", "lora", "mqtt"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "custom",
        "current": { "text": "MeshCore", "value": "MeshCore" },
        "options": [
          { "text": "MeshCore", "value": "MeshCore", "selected": true }
        ],
        "query": "MeshCore"
      },
      {
        "name": "node",
        "label": "Observer Node",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"node_id\", predicate: (r) => r._measurement == \"meshcore_adverts\")",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "node_type",
        "label": "Node Type",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"type\", predicate: (r) => r._measurement == \"meshcore_adverts\")",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Node Map",
      "type": "geomap",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "view": {
          "allLayers": true,
          "id": "fit",
          "lat": 47.6,
          "lon": -122.3,
          "zoom": 9
        },
        "basemap": {
          "type": "xyz",
          "config": {
            "url": "https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png",
            "attribution": "&copy; OpenStreetMap contributors &copy; CARTO"
          }
        },
        "layers": [
          {
            "name": "Repeaters",
            "type": "markers",
            "config": {
              "showLegend": true,
              "style": {
                "size": { "fixed": 8 },
                "color": { "fixed": "green" },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "opacity": 0.9
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "tooltip": true,
            "filterData": {
              "id": "byRefId",
              "options": "repeaters"
            }
          },
          {
            "name": "Chat Nodes",
            "type": "markers",
            "config": {
              "showLegend": true,
              "style": {
                "size": { "fixed": 8 },
                "color": { "fixed": "blue" },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "opacity": 0.9
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "tooltip": true,
            "filterData": {
              "id": "byRefId",
              "options": "chat"
            }
          },
          {
            "name": "Room Servers",
            "type": "markers",
            "config": {
              "showLegend": true,
              "style": {
                "size": { "fixed": 8 },
                "color": { "fixed": "purple" },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "opacity": 0.9
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "lat",
              "longitude": "lon"
            },
            "tooltip": true,
            "filterData": {
              "id": "byRefId",
              "options": "room"
            }
          }
        ],
        "tooltip": { "mode": "details" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type == \"repeater\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => r.lat != 0.0 or r.lon != 0.0)\n  |> group(columns: [\"id\", \"name\", \"type\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 1)\n  |> group()\n  |> keep(columns: [\"_time\", \"id\", \"name\", \"type\", \"lat\", \"lon\", \"hops\", \"snr\"])",
          "refId": "repeaters"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type == \"chat\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => r.lat != 0.0 or r.lon != 0.0)\n  |> group(columns: [\"id\", \"name\", \"type\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 1)\n  |> group()\n  |> keep(columns: [\"_time\", \"id\", \"name\", \"type\", \"lat\", \"lon\", \"hops\", \"snr\"])",
          "refId": "chat"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type == \"room\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => r.lat != 0.0 or r.lon != 0.0)\n  |> group(columns: [\"id\", \"name\", \"type\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 1)\n  |> group()\n  |> keep(columns: [\"_time\", \"id\", \"name\", \"type\", \"lat\", \"lon\", \"hops\", \"snr\"])",
          "refId": "room"
        }
      ]
    },
    {
      "title": "Summary",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Total Nodes Seen",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": 0 } ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\" and r._field == \"snr\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type =~ /${node_type:regex}/)\n  |> group(columns: [\"id\"])\n  |> last()\n  |> group()\n  |> count()\n  |> rename(columns: {\"_value\": \"nodes\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Node Type Breakdown",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 8, "x": 4, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels._field}",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\" and r._field == \"snr\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type =~ /${node_type:regex}/)\n  |> group(columns: [\"id\", \"type\"])\n  |> last()\n  |> group(columns: [\"type\"])\n  |> count()\n  |> map(fn: (r) => ({_value: r._value, _field: r.type}))\n  |> group(columns: [\"_field\"])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg SNR",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": -5 },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\" and r._field == \"snr\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type =~ /${node_type:regex}/)\n  |> group(columns: [\"id\"])\n  |> last()\n  |> group()\n  |> keep(columns: [\"_value\"])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Hops",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\" and r._field == \"hops\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type =~ /${node_type:regex}/)\n  |> group(columns: [\"id\"])\n  |> last()\n  |> group()\n  |> keep(columns: [\"_value\"])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "With Location",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 15 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": 0 } ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\" and r._field == \"lat\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type =~ /${node_type:regex}/)\n  |> group(columns: [\"id\"])\n  |> last()\n  |> group()\n  |> filter(fn: (r) => r._value != 0.0)\n  |> count()\n  |> rename(columns: {\"_value\": \"nodes\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Nodes",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Discovered Nodes",
      "type": "table",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [
              { "id": "displayName", "value": "Node Name" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "id" },
            "properties": [
              { "id": "displayName", "value": "Public Key" },
              { "id": "custom.width", "value": 160 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "type" },
            "properties": [
              { "id": "displayName", "value": "Type" },
              { "id": "custom.width", "value": 110 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "mappings", "value": [
                  { "type": "value", "options": {
                      "repeater": { "text": "Repeater", "color": "green" },
                      "chat": { "text": "Chat Node", "color": "blue" },
                      "room": { "text": "Room Server", "color": "purple" }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "lat" },
            "properties": [
              { "id": "displayName", "value": "Latitude" },
              { "id": "custom.width", "value": 100 },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "lon" },
            "properties": [
              { "id": "displayName", "value": "Longitude" },
              { "id": "custom.width", "value": 110 },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "hops" },
            "properties": [
              { "id": "displayName", "value": "Hops" },
              { "id": "custom.width", "value": 60 },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 3 },
                    { "color": "orange", "value": 5 },
                    { "color": "red", "value": 8 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "snr" },
            "properties": [
              { "id": "displayName", "value": "SNR" },
              { "id": "unit", "value": "dB" },
              { "id": "custom.width", "value": 80 },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": -5 },
                    { "color": "yellow", "value": 0 },
                    { "color": "green", "value": 5 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last Seen" },
            "properties": [
              { "id": "custom.width", "value": 160 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Adverts" },
            "properties": [
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^(_start|_stop|_measurement|node_id|topic|host|advert_ts|_time)$" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          { "desc": false, "displayName": "Type" }
        ],
        "footer": {
          "show": true,
          "reducer": ["count"],
          "countRows": true
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "base = from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"meshcore_adverts\")\n  |> filter(fn: (r) => r.node_id =~ /${node:regex}/)\n  |> filter(fn: (r) => r.type =~ /${node_type:regex}/)\n\nlast = base\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group(columns: [\"id\", \"name\", \"type\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 1)\n  |> keep(columns: [\"_time\", \"id\", \"name\", \"type\", \"lat\", \"lon\", \"hops\", \"snr\"])\n  |> rename(columns: {\"_time\": \"Last Seen\"})\n\ncounts = base\n  |> filter(fn: (r) => r._field == \"snr\")\n  |> group(columns: [\"id\"])\n  |> count()\n  |> keep(columns: [\"id\", \"_value\"])\n  |> rename(columns: {\"_value\": \"Adverts\"})\n\njoin(tables: {l: last, r: counts}, on: [\"id\"])\n  |> group()\n  |> sort(columns: [\"type\", \"name\"])",
          "refId": "A"
        }
      ]
    }
  ]
}
